# NemoClaw environment variables
# Copy this to .env in the project root and fill in values.
# All vars are prefixed with NEMOCLAW_

# LLM Configuration
# NEMOCLAW_LLM_BASE_URL=http://localhost:11434/v1
# NEMOCLAW_LLM_MODEL=qwen3.5:35b
# NEMOCLAW_LLM_API_KEY=ollama
# NEMOCLAW_LLM_TEMPERATURE=0.7
# NEMOCLAW_LLM_MAX_TOKENS=4096

# Base directory for NemoClaw data
# NEMOCLAW_BASE_DIR=~/.nemoclaw

# Persona file path
# NEMOCLAW_PERSONA_PATH=alice/ALICE.md

# Transport (cli or telegram)
# NEMOCLAW_TRANSPORT=cli

# Agent loop max turns
# NEMOCLAW_MAX_TURNS=25

# Telegram (Phase 6)
# NEMOCLAW_TELEGRAM_TOKEN=your-bot-token-here
